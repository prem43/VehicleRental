@model VehicleRental.Models.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2 class="gradient-text">Welcome Back!</h2>
            <p>Sign in to access your account</p>
        </div>

        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-glow">
                <i class="fas fa-sign-in-alt me-2"></i> Sign In
            </button>

            <div class="text-center mt-3">
                <a asp-action="ForgotPassword" class="text-muted">Forgot your password?</a>
            </div>

            <div class="divider">
                <span>or</span>
            </div>

            <div class="social-auth">
                <button type="button" class="btn btn-outline-light btn-block mb-2">
                    <i class="fab fa-google me-2"></i> Continue with Google
                </button>
                <button type="button" class="btn btn-outline-light btn-block">
                    <i class="fab fa-facebook-f me-2"></i> Continue with Facebook
                </button>
            </div>

            <div class="auth-footer text-center mt-4">
                Don't have an account? <a asp-action="Register" class="text-primary">Sign up</a>
            </div>
        </form>
    </div>
</div>

    <style>
        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
                        url('https://images.unsplash.com/photo-1503376780353-7e6692767b70?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80') center/cover no-repeat;
        }

        .auth-card {
            background: rgba(18, 18, 18, 0.9);
            border-radius: 10px;
            padding: 2.5rem;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .auth-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .auth-header h2 {
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .auth-header p {
            color: rgba(255, 255, 255, 0.7);
        }

        .auth-form .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            color: white;
            margin-bottom: 0.5rem;
            display: block;
        }

        .form-control {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            padding: 0.75rem 1rem;
            width: 100%;
            border-radius: 5px;
        }

        .form-control:focus {
            background: rgba(0, 0, 0, 0.5);
            border-color: var(--primary-color);
            color: white;
            box-shadow: 0 0 0 0.25rem rgba(110, 69, 226, 0.25);
        }

        .btn-block {
            width: 100%;
            padding: 0.75rem;
        }

        .divider {
            display: flex;
            align-items: center;
            margin: 1.5rem 0;
            color: rgba(255, 255, 255, 0.5);
        }

        .divider::before,
        .divider::after {
            content: "";
            flex: 1;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .divider::before {
            margin-right: 1rem;
        }

        .divider::after {
            margin-left: 1rem;
        }

        .social-auth .btn {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-footer {
            color: rgba(255, 255, 255, 0.7);
        }

        @@media (max-width: 576px) {
            .auth-card {
                padding: 1.5rem;
            }
        }
    </style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}