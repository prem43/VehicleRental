@model VehicleRental.Models.AdminModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<!-- Content Header (Page header) - Added from previous version -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Dashboard</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Home</a></li>
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <!-- Small boxes (Stat box) - Keeping your current layout but adding icons from previous version -->
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@Model.PendingSellerCount</h3>
                        <p>Pending Sellers</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-user-clock"></i>
                    </div>
                    <a asp-action="PendingSellers" class="small-box-footer">
                        More info <i class="fas fa-arrow-circle-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@Model.PendingVehicleCount</h3>
                        <p>Pending Vehicles</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-car"></i>
                    </div>
                    <a asp-action="PendingVehicles" class="small-box-footer">
                        More info <i class="fas fa-arrow-circle-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@Model.ActiveUsersCount</h3>
                        <p>Active Users</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <a asp-action="UserManagement" class="small-box-footer">
                        More info <i class="fas fa-arrow-circle-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3>@Model.TotalVehiclesCount</h3>
                        <p>Total Vehicles</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-car-side"></i>
                    </div>
                    <a asp-action="PendingVehicles" class="small-box-footer">
                        More info <i class="fas fa-arrow-circle-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Main row - Combined layout from both versions -->
        <div class="row">
            <!-- Left col - Keeping your current vehicle cards but adding chart from previous version -->
            <section class="col-lg-7 connectedSortable">
                <!-- Monthly Registrations Chart from previous version -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-chart-pie mr-1"></i>
                            Monthly Registrations
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="tab-content p-0">
                            <canvas id="registrationsChart" height="300"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Recently Approved Vehicles - Your current version with better layout -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-car mr-1"></i>
                            Recently Approved Vehicles
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var vehicle in Model.RecentlyApprovedVehicles)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card">
                                        @if (vehicle.ImageUrls.Any())
                                        {
                                            <img src="@vehicle.ImageUrls.First()" class="card-img-top" alt="@vehicle.Make @vehicle.Model">
                                        }
                                        else
                                        {
                                            <div class="text-center p-4 bg-light">
                                                <i class="fas fa-car fa-5x text-muted"></i>
                                            </div>
                                        }
                                        <div class="card-body">
                                            <h5 class="card-title">@vehicle.Make @vehicle.Model (@vehicle.Year)</h5>
                                            <p class="card-text">Approved: @vehicle.ApprovalDate?.ToString("g")</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </section>

            <!-- Right col - Keeping your current activities but adding quick actions from previous version -->
            <section class="col-lg-5 connectedSortable">
                <!-- Quick Actions from previous version -->
                <div class="card bg-gradient-primary">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-bolt mr-1"></i>
                            Quick Actions
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-6">
                                <button class="btn btn-block btn-outline-light mb-3">
                                    <i class="fas fa-user-plus mr-2"></i>Add User
                                </button>
                            </div>
                            <div class="col-6">
                                <button class="btn btn-block btn-outline-light mb-3">
                                    <i class="fas fa-car mr-2"></i>Add Vehicle
                                </button>
                            </div>
                            <div class="col-6">
                                <button class="btn btn-block btn-outline-light mb-3">
                                    <i class="fas fa-file-invoice-dollar mr-2"></i>Generate Report
                                </button>
                            </div>
                            <div class="col-6">
                                <button class="btn btn-block btn-outline-light mb-3">
                                    <i class="fas fa-cog mr-2"></i>Settings
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activities - Your current version with better styling -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-history mr-1"></i>
                            Recent Activities
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="products-list product-list-in-card pl-2 pr-2">
                            @foreach (var activity in Model.RecentActivities)
                            {
                                <li class="item">
                                    <div class="product-info">
                                        <a href="javascript:void(0)" class="product-title">
                                            @activity.UserEmail
                                            <span class="badge @GetBadgeClass(activity.Action) float-right">@activity.Action</span>
                                        </a>
                                        <span class="product-description">
                                            @activity.Date.ToString("g")
                                        </span>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </section>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Registration Chart - You'll need to add monthly data to your model
        var ctx = document.getElementById('registrationsChart').getContext('2d');
        var chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Users',
                    backgroundColor: '#007bff',
                    data: [12, 19, 15, 27, 34, 42, 38, 45, 52, 60, 55, 68] // Replace with real data
                }, {
                    label: 'Sellers',
                    backgroundColor: '#28a745',
                    data: [5, 8, 7, 12, 15, 18, 16, 20, 22, 25, 23, 30] // Replace with real data
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                    title: {
                        display: true,
                        text: 'Monthly User Registrations'
                    }
                }
            }
        });
    </script>
}

@functions {
    string GetBadgeClass(string action)
    {
        if (action.Contains("Approve")) return "badge-success";
        if (action.Contains("Reject")) return "badge-danger";
        if (action.Contains("Suspend")) return "badge-warning";
        return "badge-info";
    }
}