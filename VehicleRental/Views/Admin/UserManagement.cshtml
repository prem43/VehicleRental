@model List<VehicleRental.Models.AdminModels.UserManagementModel>
@{
    ViewData["Title"] = "User Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">User Management</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">All Users</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Registered</th>
                            <th>Last Login</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@user.Role</td>
                                <td>@user.RegistrationDate.ToString("d")</td>
                                <td>@(user.LastLoginDate?.ToString("g") ?? "Never")</td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        @if (user.Role == "Seller")
                                        {
                                            <button class="btn btn-info btn-sm" onclick="viewSellerDetails('@user.Email')">
                                                Details
                                            </button>
                                        }
                                        <button class="btn btn-warning btn-sm" onclick="resetPassword('@user.Email')">
                                            Reset Password
                                        </button>
                                        @if (user.IsActive)
                                        {
                                            <button class="btn btn-danger btn-sm" onclick="toggleUserStatus(@user.UserId, false)">
                                                Deactivate
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-success btn-sm" onclick="toggleUserStatus(@user.UserId, true)">
                                                Activate
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleUserStatus(userId, activate) {
            if (confirm(activate ? "Activate this user?" : "Deactivate this user?")) {
                $.post('/Admin/ToggleUserStatus', { userId: userId, activate: activate }, function() {
                    location.reload();
                });
            }
        }

        function resetPassword(email) {
            alert("Password reset functionality would be implemented here for: " + email);
            // Typically this would send a password reset link to the user's email
        }

        function viewSellerDetails(email) {
            alert("Seller details would be shown for: " + email);
            // This would typically open a modal with seller details and statistics
        }
    </script>
}