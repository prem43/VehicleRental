@model VehicleRental.Models.AdminModels.SellerApprovalModel

<div class="row">
    <div class="col-md-6">
        <h4>Basic Information</h4>
        <dl class="row">
            <dt class="col-sm-4">Full Name:</dt>
            <dd class="col-sm-8">@Model.FullName</dd>

            <dt class="col-sm-4">Email:</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Phone:</dt>
            <dd class="col-sm-8">@Model.PhoneNumber</dd>

            <dt class="col-sm-4">Registration Date:</dt>
            <dd class="col-sm-8">@Model.RegistrationDate.ToString("d")</dd>
        </dl>
    </div>

    <div class="col-md-6">
        <h4>Company Information</h4>
        <dl class="row">
            <dt class="col-sm-4">Company Name:</dt>
            <dd class="col-sm-8">@Model.CompanyName</dd>

            <dt class="col-sm-4">Tax ID:</dt>
            <dd class="col-sm-8">@Model.TaxId</dd>

            <dt class="col-sm-4">Address:</dt>
            <dd class="col-sm-8">@Model.Address</dd>

            <dt class="col-sm-4">Country:</dt>
            <dd class="col-sm-8">@Model.Country</dd>
        </dl>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <h4>Documents</h4>
        @if (!string.IsNullOrEmpty(Model.TaxDocumentPath))
        {
            <div class="mb-2">
                <strong>Tax Document:</strong>
                <a href="@Model.TaxDocumentPath" target="_blank" class="ml-2">View Document</a>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.CompanyRegistrationPath))
        {
            <div class="mb-2">
                <strong>Company Registration:</strong>
                <a href="@Model.CompanyRegistrationPath" target="_blank" class="ml-2">View Document</a>
            </div>
        }
    </div>
</div>