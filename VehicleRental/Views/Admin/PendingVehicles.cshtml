@model List<VehicleRental.Models.AdminModels.VehicleApprovalModel>
@{
	ViewData["Title"] = "Admin Dashboard";
	Layout = "_AdminLayout";

}
<div class="container-fluid">
	<div class="card">
		<div class="card-header">
			<h3 class="card-title">Pending Vehicle Approvals</h3>
		</div>
		<div class="card-body">
			<table id="vehiclesTable" class="table table-bordered table-striped">
				<thead>
					<tr>
						<th>ID</th>
						<th>Make/Model</th>
						<th>Year</th>
						<th>Seller</th>
						<th>Submitted</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var vehicle in Model)
					{
						<tr>
							<td>@vehicle.VehicleId</td>
							<td>@vehicle.Make @vehicle.Model</td>
							<td>@vehicle.Year</td>
							<td>@vehicle.SellerName<br><small>@vehicle.SellerEmail</small></td>
							<td>@vehicle.SubmissionDate.ToString("d")</td>
							<td>
								<div class="btn-group">
									<button type="button" class="btn btn-default dropdown-toggle" data-toggle="dropdown" aria-expanded="false">
										Actions
									</button>
									<div class="dropdown-menu">
										<a class="dropdown-item view-vehicle-details" href="#" data-vehicleid="@vehicle.VehicleId">
											<i class="fas fa-eye mr-2"></i>View Details
										</a>
										<a class="dropdown-item approve-vehicle" href="#" data-vehicleid="@vehicle.VehicleId">
											<i class="fas fa-check-circle mr-2 text-success"></i>Approve
										</a>
										<a class="dropdown-item reject-vehicle" href="#" data-vehicleid="@vehicle.VehicleId">
											<i class="fas fa-times-circle mr-2 text-danger"></i>Reject
										</a>
										<div class="dropdown-divider"></div>
										<a class="dropdown-item request-more-info" href="#" data-vehicleid="@vehicle.VehicleId">
											<i class="fas fa-info-circle mr-2 text-info"></i>Request More Info
										</a>
									</div>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
</div>

<!-- Vehicle Details Modal -->
<div class="modal fade" id="vehicleDetailsModal" tabindex="-1" role="dialog" aria-labelledby="vehicleDetailsModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-xl" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="vehicleDetailsModalLabel">Vehicle Details</h5>
				<button type="button" class="close" data-dismiss="modal" aria-label="Close">
					<span aria-hidden="true">&times;</span>
				</button>
			</div>
			<div class="modal-body" id="vehicleDetailsContent">
				<!-- Content will be loaded via AJAX -->
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
			</div>
		</div>
	</div>
</div>

<!-- Approval Notes Modal -->
<div class="modal fade" id="vehicleApprovalNotesModal" tabindex="-1" role="dialog" aria-labelledby="vehicleApprovalNotesModalLabel" aria-hidden="true">
	<div class="modal-dialog" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="vehicleApprovalNotesModalLabel">Add Notes</h5>
				<button type="button" class="close" data-dismiss="modal" aria-label="Close">
					<span aria-hidden="true">&times;</span>
				</button>
			</div>
			<form id="vehicleApprovalNotesForm">
				<input type="hidden" id="vehicleActionType" name="Action" />
				<input type="hidden" id="targetVehicleId" name="TargetId" />
				<input type="hidden" name="TargetType" value="Vehicle" />
				<div class="modal-body">
					<div class="form-group">
						<label for="vehicleApprovalNotes">Notes (Optional)</label>
						<textarea class="form-control" id="vehicleApprovalNotes" name="Notes" rows="3"></textarea>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
					<button type="submit" class="btn btn-primary">Submit</button>
				</div>
			</form>
		</div>
	</div>
</div>

@section Scripts {
	<script>
		$(document).ready(function() {
			$('#vehiclesTable').DataTable({
				"responsive": true,
				"autoWidth": false,
			});

			// View vehicle details
			$('.view-vehicle-details').click(function(e) {
				e.preventDefault();
				var vehicleId = $(this).data('vehicleid');

				$.get('/Admin/GetVehicleDetails', { vehicleId: vehicleId }, function(data) {
					$('#vehicleDetailsContent').html(data);
					$('#vehicleDetailsModal').modal('show');
				});
			});

			// Approval actions
			$('.approve-vehicle, .reject-vehicle, .request-more-info').click(function(e) {
				e.preventDefault();
				var vehicleId = $(this).data('vehicleid');
				var action = $(this).hasClass('approve-vehicle') ? 'Approve' :
							 $(this).hasClass('reject-vehicle') ? 'Reject' : 'UnderObservation';

				$('#targetVehicleId').val(vehicleId);
				$('#vehicleActionType').val(action);
				$('#vehicleApprovalNotesModalLabel').text(action + ' Vehicle');
				$('#vehicleApprovalNotesModal').modal('show');
			});

			// Submit approval form
			// $('#vehicleApprovalNotesForm').submit(function(e) {
			//     debugger;
			//     e.preventDefault();
			//     var formData = $(this).serialize();

			//     $.post('/Admin/ProcessApproval', formData, function() {
			//         $('#vehicleApprovalNotesModal').modal('hide');
			//         location.reload();
			//     });
			// });
						$('#vehicleApprovalNotesForm').submit(function(e) {
							debugger;
			e.preventDefault();

			// Get form data as FormData object
			var formData = new FormData(this);

			// Add anti-forgery token
			formData.append('__RequestVerificationToken',
				document.querySelector('input[name="__RequestVerificationToken"]').value);

			fetch('/Admin/ProcessApproval', {
				method: 'POST',
				body: formData,
				headers: {
					'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
				}
			}).then(() => {
				$('#vehicleApprovalNotesModal').modal('hide');
				location.reload();
			});
		});
		});
	</script>
}