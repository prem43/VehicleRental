<!DOCTYPE html>
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CityRide Admin</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- AdminLTE -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a asp-controller="Admin" asp-action="Index" class="nav-link">Dashboard</a>
                </li>
            </ul>

            <!-- Right navbar links -->
            <ul class="navbar-nav ml-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link" data-toggle="dropdown" href="#">
                        <i class="fas fa-user-cog"></i> Admin Panel
                    </a>
                    <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
                        <a href="#" class="dropdown-item">
                            <i class="fas fa-user mr-2"></i> Profile
                        </a>
                        <div class="dropdown-divider"></div>
                        <form class="form-inline" asp-controller="Account" asp-action="Logout">
                            <button type="submit" class="dropdown-item">
                                <i class="fas fa-sign-out-alt mr-2"></i> Logout
                            </button>
                        </form>
                    </div>
                </li>
            </ul>
        </nav>

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a asp-controller="Admin" asp-action="Index" class="brand-link">
                <img src="~/images/logo.png" alt="CityRide Logo" class="brand-image img-circle elevation-3" style="opacity: .8">
                <span class="brand-text font-weight-light">CityRide Admin</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Index" class="nav-link @(currentAction == "Index" ? "active" : "")">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="UserManagement" class="nav-link @(currentAction == "UserManagement" ? "active" : "")">
                                <i class="nav-icon fas fa-users"></i>
                                <p>User Management</p>
                            </a>
                        </li>
                        <!-- In the sidebar menu -->
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="PendingSellers" class="nav-link @(currentAction == "PendingSellers" ? "active" : "")">
                                <i class="nav-icon fas fa-user-clock"></i>
                                <p>Pending Sellers</p>
                                <span class="badge badge-info right pending-sellers-count">0</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="PendingVehicles" class="nav-link @(currentAction == "PendingVehicles" ? "active" : "")">
                                <i class="nav-icon fas fa-car"></i>
                                <p>Pending Vehicles</p>
                                <span class="badge badge-warning right pending-vehicles-count">0</span>
                            </a>
                        </li>
                        <!-- Inside the sidebar menu -->
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="RentalRequests" class="nav-link @(currentAction == "RentalRequests" ? "active" : "")">
                                <i class="nav-icon fas fa-calendar-check"></i>
                                <p>Rental Requests</p>
                                <span class="badge badge-primary right rental-requests-count">0</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Transactions" class="nav-link @(currentAction == "Transactions" ? "active" : "")">
                                <i class="nav-icon fas fa-receipt"></i>
                                <p>Transactions</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="main-footer">
            <strong>Copyright &copy; @DateTime.Now.Year CityRide Admin.</strong>
            All rights reserved.
        </footer>
    </div>

    <!-- REQUIRED SCRIPTS -->
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap 4 -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- AdminLTE App -->
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Custom Scripts -->
    <script src="~/js/admin.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <!-- At the bottom of the file before </body> -->
    <script>
        $(document).ready(function() {
            // Fetch and update pending counts
            $.get('/Admin/GetPendingCounts', function(data) {
                $('.pending-sellers-count').text(data.pendingSellers);
                $('.pending-vehicles-count').text(data.pendingVehicles);
                 $('.rental-requests-count').text(data.pendingRentalRequests);
            });
        });


    </script>
</body>
</html>
