@using System.Security.Claims
@inject VehicleRental.Services.IServices.IAccountService AccountService
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CityRide</title>
    <!-- Premium CSS Libraries -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Glide.js/3.6.0/css/glide.core.min.css" />
    
    <!-- Font Awesome -->
</head>
<body>
    <!-- 3D Animated Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top navbar-dark bg-transparent">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-car me-2"></i>
                <span class="gradient-text">CityRide</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#navbarOffcanvas">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="offcanvas offcanvas-end bg-dark" tabindex="-1" id="navbarOffcanvas">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title gradient-text">CityRide</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
                </div>
                <div class="offcanvas-body">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            var role = User.FindFirst(ClaimTypes.Role)?.Value;
                            if (role == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                                </li>
                            }
                            else if (role == "Seller")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Seller" asp-action="Index">Seller Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Seller" asp-action="Vehicles">My Vehicles</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Vehicles" asp-action="Index">Rent a Vehicle</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Vehicles" asp-action="MyRentals">My Rentals</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Vehicles" asp-action="Index">Vehicles</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="#features">Features</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#testimonials">Testimonials</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#contact">Contact</a>
                        </li>
                    </ul>

                    <div class="d-flex ms-lg-3">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-light btn-glow dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle me-1"></i> @User.Identity.Name
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user me-2"></i>Profile</a></li>
                                    @if (User.FindFirst(ClaimTypes.Role)?.Value == "Seller")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Account" asp-action="SellerSettings"><i class="fas fa-cog me-2"></i>Settings</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form class="form-inline" asp-controller="Account" asp-action="Logout">
                                            <button type="submit" class="dropdown-item"><i class="fas fa-sign-out-alt me-2"></i>Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-light btn-glow me-2" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i> Sign In
                            </a>
                            <a class="btn btn-primary btn-glow" asp-controller="Account" asp-action="Register">
                                <i class="fas fa-user-plus me-1"></i> Sign Up
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <partial name="_ChatBot" />

    <!-- 3D Animated Footer -->
    <footer class="footer bg-dark pt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h3 class="gradient-text mb-4">CityRide</h3>
                    <p>Simple city ride rental service with verified vehicles and clear booking flow.</p>
                    <div class="social-icons mt-4">
                        <a href="#" class="icon-circle me-2"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="icon-circle me-2"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="icon-circle me-2"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="icon-circle"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h5 class="text-light mb-4">Quick Links</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-muted">Home</a></li>
                        <li class="mb-2"><a asp-controller="Vehicles" asp-action="Index" class="text-muted">Vehicles</a></li>
                        <li class="mb-2"><a href="#features" class="text-muted">Features</a></li>
                        <li class="mb-2"><a href="#testimonials" class="text-muted">Testimonials</a></li>
                        <li><a href="#contact" class="text-muted">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h5 class="text-light mb-4">Contact Us</h5>
                    <ul class="list-unstyled text-muted">
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2"></i> Patna ,Bihar </li>
                        <li class="mb-2"><i class="fas fa-phone me-2"></i>+91 9123188119</li>
                        <li><i class="fas fa-envelope me-2"></i> info@cityride.com</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h5 class="text-light mb-4">Newsletter</h5>
                    <p class="text-muted">Subscribe for exclusive offers</p>
                    <div class="input-group mb-3">
                        <input type="email" class="form-control bg-black border-dark" placeholder="Your Email">
                        <button class="btn btn-primary" type="button">Subscribe</button>
                    </div>
                </div>
            </div>
            <hr class="my-4 bg-secondary">
            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <p class="text-muted mb-0">&copy; @DateTime.Now.Year CityRide. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="text-muted me-3">Privacy Policy</a>
                    <a href="#" class="text-muted">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Back to Top Button -->
    <a href="#home" class="back-to-top btn btn-primary btn-lg rounded-circle shadow">
        <i class="fas fa-arrow-up"></i>
    </a>

    <!-- JavaScript Libraries -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Glide.js/3.6.0/glide.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.4/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.4/ScrollTrigger.min.js"></script>
    

    
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
         $(document).ready(function() {
            $('#dataTable').DataTable();
        });
        // Initialize AOS animations
        AOS.init({
            duration: 800,
            easing: 'ease-in-out',
            once: true
        });

        // Back to top button
        $(window).scroll(function() {
            if ($(this).scrollTop() > 300) {
                $('.back-to-top').addClass('show');
            } else {
                $('.back-to-top').removeClass('show');
            }
        });

        $('.back-to-top').click(function() {
            $('html, body').animate({scrollTop: 0}, 'smooth');
            return false;
        });

        // Seller fields toggle for registration
        $(document).ready(function() {
            $('#Role').change(function() {
                if ($(this).val() === 'Seller') {
                    $('#sellerFields').removeClass('d-none');
                    $('#CompanyName, #TaxId').prop('required', true);
                } else {
                    $('#sellerFields').addClass('d-none');
                    $('#CompanyName, #TaxId').prop('required', false);
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
