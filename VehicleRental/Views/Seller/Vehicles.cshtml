@model List<VehicleRental.Models.SellerModels.VehicleListingModel>
@{
    ViewData["Title"] = "My Vehicles";
    Layout = "_SellerLayout";
}

<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">My Vehicles</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">My Vehicles</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">All Vehicles</h3>
                        <div class="card-tools">
                            <a asp-action="AddVehicle" class="btn btn-primary btn-sm">
                                <i class="fas fa-plus"></i> Add New Vehicle
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <table id="vehiclesTable" class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>Make/Model</th>
                                    <th>Year</th>
                                    <th>Rate</th>
                                    <th>Status</th>
                                    <th>Availability</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vehicle in Model)
                                {
                                    <tr>
                                        <td>@vehicle.Make @vehicle.Model</td>
                                        <td>@vehicle.Year</td>
                                        <td>@vehicle.DailyRate.ToString("C")/day</td>
                                        <td>
                                            <span class="badge @(vehicle.Status == "Approved" ? "badge-success" :
                                                              vehicle.Status == "Pending" ? "badge-warning" : "badge-danger")">
                                                @vehicle.Status
                                            </span>
                                        </td>
                                        <td>
                                            @if (vehicle.Status == "Approved")
                                            {
                                                <div class="custom-control custom-switch">
                                                    <input type="checkbox" class="custom-control-input availability-toggle"
                                                           id="toggle-@vehicle.VehicleId" data-id="@vehicle.VehicleId"
                                                    @(vehicle.IsAvailable ? "checked" : "")>
                                                    <label class="custom-control-label" for="toggle-@vehicle.VehicleId">
                                                        @(vehicle.IsAvailable ? "Available" : "Rented")
                                                    </label>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="#" class="btn btn-sm btn-info" data-toggle="modal" data-target="#vehicleModal-@vehicle.VehicleId">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="#" class="btn btn-sm btn-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        </td>
                                    </tr>

                                    <!-- Vehicle Details Modal -->
                                    <div class="modal fade" id="vehicleModal-@vehicle.VehicleId" tabindex="-1" role="dialog" aria-labelledby="vehicleModalLabel-@vehicle.VehicleId" aria-hidden="true">
                                        <div class="modal-dialog modal-lg" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title" id="vehicleModalLabel-@vehicle.VehicleId">
                                                        @vehicle.Year @vehicle.Make @vehicle.Model
                                                    </h5>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <h5>Description</h5>
                                                            <p>@vehicle.Description</p>

                                                            <h5 class="mt-4">Details</h5>
                                                            <ul class="list-group list-group-flush">
                                                                <li class="list-group-item">
                                                                    <strong>Daily Rate:</strong> @vehicle.DailyRate.ToString("C")
                                                                </li>
                                                                <li class="list-group-item">
                                                                    <strong>Minimum Rental Days:</strong> @vehicle.MinimumRentalDays
                                                                </li>
                                                                <li class="list-group-item">
                                                                    <strong>Status:</strong>
                                                                    <span class="badge @(vehicle.Status == "Approved" ? "badge-success" :
                                                                                      vehicle.Status == "Pending" ? "badge-warning" : "badge-danger")">
                                                                        @vehicle.Status
                                                                    </span>
                                                                </li>
                                                            </ul>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <h5>Images</h5>
                                                            <div class="row">
                                                                @foreach (var image in vehicle.ImageUrls.Take(3))
                                                                {
                                                                    <div class="col-4 mb-3">
                                                                        <img src="@image" class="img-fluid img-thumbnail" alt="Vehicle Image">
                                                                    </div>
                                                                }
                                                            </div>
                                                            <h5 class="mt-4">Documents</h5>
                                                            <ul class="list-group">
                                                                @foreach (var doc in vehicle.DocumentUrls)
                                                                {
                                                                    <li class="list-group-item">
                                                                        <a href="@doc" target="_blank" class="text-primary">
                                                                            <i class="fas fa-file-pdf mr-2"></i>View Document
                                                                        </a>
                                                                    </li>
                                                                }
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            $('#vehiclesTable').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
            });

            // Availability toggle
            $(document).on('change', '.availability-toggle', function() {
                var vehicleId = $(this).data('id');
                var isAvailable = $(this).is(':checked');

                $.post('/Seller/ToggleAvailability', {
                    vehicleId: vehicleId,
                    isAvailable: isAvailable
                }, function(response) {
                    if (!response.success) {
                        // Revert the toggle if the operation failed
                        $(this).prop('checked', !isAvailable);
                        alert('Failed to update availability. Please try again.');
                    }
                });
            });
        });
    </script>
}