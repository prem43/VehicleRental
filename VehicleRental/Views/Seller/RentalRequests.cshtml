@model List<VehicleRental.Models.SellerModels.RentalRequestModel>
@{
    ViewData["Title"] = "Rental Requests";
    Layout = "_SellerLayout";
}

<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Rental Requests</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Rental Requests</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- Main content -->
<section class="content">
    @Html.AntiForgeryToken()
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">All Rental Requests</h3>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="requestsTable" class="table table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>Vehicle</th>
                                        <th>Customer</th>
                                        <th>Rental Period</th>
                                        <th>Days</th>
                                        <th>Total Amount</th>
                                        <th>Status</th>
                                        <th>Request Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in Model)
                                    {
                                        <tr>
                                            <td>@request.VehicleName</td>
                                            <td>@request.UserName</td>
                                            <td>@request.StartDate.ToString("MMM d, yyyy") - @request.EndDate.ToString("MMM d, yyyy")</td>
                                            <td>@request.RentalDays</td>
                                            <td>@request.TotalAmount.ToString("C")</td>
                                            <td>
                                                <span class="badge @(request.Status == "Pending" ? "badge-warning" :
                                                                  request.Status == "Approved" ? "badge-success" : "badge-danger")">
                                                    @request.Status
                                                </span>
                                            </td>
                                            <td>@request.RequestDate.ToString("MMM d, yyyy")</td>
                                            <td>
                                                @if (request.Status == "Pending")
                                                {
                                                    <form asp-action="ProcessRentalRequest" method="post" class="d-inline">
                                                        <input type="hidden" name="RequestId" value="@request.RequestId" />
                                                        <input type="hidden" name="Action" value="Approve" />
                                                        <input type="hidden" name="Reason" value="" />
                                                        <button class="btn btn-sm btn-success" type="submit">
                                                            <i class="fas fa-check"></i> Approve
                                                        </button>
                                                    </form>
                                                    <button class="btn btn-sm btn-danger reject-btn" data-id="@request.RequestId">
                                                        <i class="fas fa-times"></i> Reject
                                                    </button>
                                                }
                                                <a href="#" class="btn btn-sm btn-info" data-toggle="modal" data-target="#requestModal-@request.RequestId">
                                                    <i class="fas fa-eye"></i> Details
                                                </a>
                                            </td>
                                        </tr>

                                        <!-- Request Details Modal -->
                                        <div class="modal fade" id="requestModal-@request.RequestId" tabindex="-1" role="dialog" aria-labelledby="requestModalLabel-@request.RequestId" aria-hidden="true">
                                            <div class="modal-dialog" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title" id="requestModalLabel-@request.RequestId">
                                                            Rental Request Details
                                                        </h5>
                                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                            <span aria-hidden="true">&times;</span>
                                                        </button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <div class="row">
                                                            <div class="col-md-6">
                                                                <h6>Vehicle Information</h6>
                                                                <p><strong>Vehicle:</strong> @request.VehicleName</p>
                                                                <p><strong>Rental Period:</strong> @request.StartDate.ToString("MMM d, yyyy") to @request.EndDate.ToString("MMM d, yyyy")</p>
                                                                <p><strong>Total Days:</strong> @request.RentalDays</p>
                                                                <p><strong>Total Amount:</strong> @request.TotalAmount.ToString("C")</p>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <h6>Customer Information</h6>
                                                                <p><strong>Name:</strong> @request.UserName</p>
                                                                <p><strong>Email:</strong> @request.UserEmail</p>
                                                                <p><strong>ID Proof:</strong> @request.IdProofNumber</p>
                                                            </div>
                                                        </div>
                                                        <hr>
                                                        <div class="row">
                                                            <div class="col-md-5">
                                                                <h6>Customer Photo</h6>
                                                                @if (!string.IsNullOrWhiteSpace(request.CustomerImageUrl))
                                                                {
                                                                    <img src="@request.CustomerImageUrl" class="img-fluid img-thumbnail mb-2" alt="Customer photo">
                                                                    <a href="@request.CustomerImageUrl" target="_blank" download class="btn btn-sm btn-outline-primary">
                                                                        <i class="fas fa-download"></i> Download Photo
                                                                    </a>
                                                                }
                                                                else
                                                                {
                                                                    <p class="text-muted">No photo uploaded.</p>
                                                                }
                                                            </div>
                                                            <div class="col-md-7">
                                                                <h6>Submitted Documents</h6>
                                                                @if (request.DocumentUrls.Any())
                                                                {
                                                                    <ul class="list-group">
                                                                        @foreach (var doc in request.DocumentUrls)
                                                                        {
                                                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                                                <span><i class="fas fa-file-alt mr-2"></i>@System.IO.Path.GetFileName(doc)</span>
                                                                                <a href="@doc" target="_blank" download class="btn btn-sm btn-outline-primary">Download</a>
                                                                            </li>
                                                                        }
                                                                    </ul>
                                                                }
                                                                else
                                                                {
                                                                    <p class="text-muted">No documents uploaded.</p>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(request.Notes))
                                                                {
                                                                    <h6 class="mt-3">User Message</h6>
                                                                    <p>@request.Notes</p>
                                                                }
                                                            </div>
                                                        </div>
                                                        <hr>
                                                        <div class="row">
                                                            <div class="col-12">
                                                                <h6>Request Status</h6>
                                                                <p>
                                                                    <strong>Status:</strong>
                                                                    <span class="badge @(request.Status == "Pending" ? "badge-warning" :
                                                                                      request.Status == "Approved" ? "badge-success" : "badge-danger")">
                                                                        @request.Status
                                                                    </span>
                                                                </p>
                                                                <p><strong>Request Date:</strong> @request.RequestDate.ToString("f")</p>
                                                                @if (request.Status == "Approved")
                                                                {
                                                                    <p><strong>Approved Date:</strong> @(request.ApprovalDate?.ToString("f") ?? "N/A")</p>
                                                                }
                                                                else if (request.Status == "Rejected")
                                                                {
                                                                    <p><strong>Rejection Reason:</strong> @(request.RejectionReason ?? "Not specified")</p>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            $('#requestsTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "order": [[6, "desc"]], // Sort by request date by default
                "info": true,
                "autoWidth": false,
                "responsive": true,
            });

            // Approve/reject buttons
            $(document).on('click', '.reject-btn', function() {
                var requestId = $(this).data('id');
                var reason = prompt('Please enter the reason for rejection:');
                if (reason !== null) {
                    var form = $('<form method="post" action="/Seller/ProcessRentalRequest"></form>');
                    form.append($('input[name="__RequestVerificationToken"]').first().clone());
                    form.append($('<input type="hidden" name="RequestId">').val(requestId));
                    form.append($('<input type="hidden" name="Action">').val('Reject'));
                    form.append($('<input type="hidden" name="Reason">').val(reason));
                    $('body').append(form);
                    form.submit();
                }
            });
        });
    </script>
}
