@{
    ViewData["Title"] = "CityRide";
}

<section id="home" class="vr-home-hero">
    <div class="container">
        <div class="vr-home-grid">
            <div class="vr-home-copy">
                <span class="vr-kicker">Vehicle rental system</span>
                <h1>Rent cars, manage listings, and approve bookings in one clean platform.</h1>
                <p>
                    A practical rental workflow for users, sellers, and admins. Browse approved vehicles,
                    send rental requests, approve listings, and complete dummy payments without extra setup.
                </p>
                <div class="vr-home-actions">
                    <a asp-controller="Vehicles" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="fas fa-car-side me-2"></i>Browse Vehicles
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-right-to-bracket me-2"></i>Sign In
                    </a>
                </div>
                <div class="vr-home-stats">
                    <div><strong>Admin</strong><span>Approvals and control</span></div>
                    <div><strong>Seller</strong><span>Listings and requests</span></div>
                    <div><strong>User</strong><span>Rentals and payment</span></div>
                </div>
            </div>

            <div class="vr-home-visual">
                <img src="~/css/Image/BMW.jpeg" alt="BMW rental vehicle" />
                <div class="vr-status-card card-left">
                    <i class="fas fa-check-circle"></i>
                    <div>
                        <strong>Approved listing</strong>
                        <span>Visible to users</span>
                    </div>
                </div>
                <div class="vr-status-card card-right">
                    <i class="fas fa-credit-card"></i>
                    <div>
                        <strong>Dummy payment</strong>
                        <span>Transaction tracked</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="vr-home-section">
    <div class="container">
        <div class="vr-section-title">
            <span class="vr-kicker">Role based access</span>
            <h2>Simple screens for every role.</h2>
            <p>Each account type sees only the actions needed for its workflow.</p>
        </div>

        <div class="vr-role-grid">
            <article class="vr-role-card">
                <div class="vr-role-icon"><i class="fas fa-user-shield"></i></div>
                <h3>Admin</h3>
                <p>Approves sellers and vehicles, manages users, checks rental requests, and views transactions.</p>
            </article>
            <article class="vr-role-card">
                <div class="vr-role-icon"><i class="fas fa-store"></i></div>
                <h3>Seller</h3>
                <p>Adds vehicles, uploads images/documents, handles rental requests, and manages availability.</p>
            </article>
            <article class="vr-role-card">
                <div class="vr-role-icon"><i class="fas fa-user"></i></div>
                <h3>User</h3>
                <p>Browses approved vehicles, creates rental requests, tracks status, and completes dummy payment.</p>
            </article>
        </div>
    </div>
</section>

<section id="vehicles" class="vr-home-section vr-fleet-section">
    <div class="container">
        <div class="vr-section-title">
            <span class="vr-kicker">Rental workflow</span>
            <h2>From listing to payment, the data stays connected.</h2>
        </div>

        <div class="vr-process-grid">
            <div class="vr-process-step">
                <span>01</span>
                <h3>Seller lists vehicle</h3>
                <p>Vehicle goes to pending approval with images and documents.</p>
            </div>
            <div class="vr-process-step">
                <span>02</span>
                <h3>Admin approves</h3>
                <p>Approved vehicles appear on the public rental page.</p>
            </div>
            <div class="vr-process-step">
                <span>03</span>
                <h3>User requests rental</h3>
                <p>Seller reviews the request and approves or rejects it.</p>
            </div>
            <div class="vr-process-step">
                <span>04</span>
                <h3>User pays dummy amount</h3>
                <p>Payment status and transaction record are saved for dashboard tracking.</p>
            </div>
        </div>

        <div class="vr-fleet-preview">
            <img src="~/css/Image/Audi.jpeg" alt="Audi rental vehicle" />
            <img src="~/css/Image/Mercedes.jpeg" alt="Mercedes rental vehicle" />
            <img src="~/css/Image/BMW.jpeg" alt="BMW rental vehicle" />
        </div>
    </div>
</section>

<section id="contact" class="vr-home-section">
    <div class="container">
        <div class="vr-home-cta">
            <div>
                <span class="vr-kicker">Need quick help?</span>
                <h2>Use the chat assistant for common concerns.</h2>
                <p>Booking, payment, seller approval, and document help are available from the floating chat widget.</p>
            </div>
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">Create Account</a>
        </div>
    </div>
</section>
